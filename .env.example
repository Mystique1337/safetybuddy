# ==========================================================================
# SafetyBuddy — environment template. Copy to .env and fill in.
#   cp .env.example .env
# NEVER commit .env (it is gitignored).
# ==========================================================================

# --- Flask ---
SECRET_KEY=change-this-to-a-random-string
FLASK_ENV=production
PORT=6768

# --- Gemma 4 vision/chat model (served by vLLM on Modal, OpenAI-compatible) ---
# Model pulled from the Hub and served by Modal (see modal_app.py).
# Options: google/gemma-4-E4B-it (L4, cheap) · google/gemma-4-26B-A4B-it (A100).
MODEL_REPO=google/gemma-4-E4B-it
# GPU type on Modal (L4 = cheapest 24GB; A10G faster; A100 for 26B-A4B/31B).
LLM_GPU=L4
# Seconds an idle GPU container stays warm before scaling to zero (lower = cheaper).
LLM_SCALEDOWN_WINDOW=120
# Max sequence / context length.
MAX_MODEL_LEN=8192

# Where the app sends chat/vision requests. After `modal deploy`, set this to the
# Gemma endpoint, e.g. https://chidi-ashinze--safetybuddy-gemma.modal.run/v1
# Leave blank locally to point the OpenAI SDK at a local vLLM/Ollama server.
LLM_BASE_URL=
# Bearer key vLLM enforces (--api-key); the app sends the same value. Keep secret.
LLM_API_KEY=
# Model names the app requests (must match what vLLM serves).
VISION_MODEL=google/gemma-4-E4B-it
CHAT_MODEL=google/gemma-4-E4B-it
# Gemma vision image token budget: 70 / 140 / 280 / 560 / 1120 (detail vs speed).
VISION_IMAGE_TOKENS=560

# --- Embeddings (nomic-embed-text-v1.5, runs on CPU) ---
EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5
EMBED_DIM=768

# --- Self-hosted Supabase (pgvector vector store + analytics) ---
# Direct Postgres URL. SafetyBuddy keeps all of its tables in its own schema so
# they never collide with other apps sharing the same Supabase instance.
SUPABASE_DB_URL=postgresql://postgres:password@your-supabase-host:5432/postgres
SUPABASE_DB_SCHEMA=safety_buddy
# Optional REST creds (not required for the direct-Postgres path used by the app).
SUPABASE_URL=https://your-supabase-host
SUPABASE_SERVICE_ROLE_KEY=

# --- RAG tuning ---
RAG_TOP_K=20
RAG_FINAL_K=5
RAG_CHUNK_CHARS=1200
RAG_CHUNK_OVERLAP=200

# --- Self-improving RAG (live fetch + ingest when local coverage is weak) ---
RAG_ENABLE_WEB_ENRICH=1
RAG_ALWAYS_ENRICH=1
RAG_COVERAGE_THRESHOLD=0.55
RAG_MIN_CHUNKS=3
RAG_ENRICH_MAX_URLS=3
RAG_DOC_TTL_DAYS=30
# Optional live web search biased to authoritative safety domains (osha.gov,
# cdc.gov, hse.gov.uk, osha.europa.eu, ...). Without a key, enrichment falls
# back to the curated seed sources in src/rag/sources.py.
TAVILY_API_KEY=
HTTP_TIMEOUT=20

# --- Generation defaults ---
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1500
